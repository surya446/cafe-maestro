{
  "name": "@workspace/admin-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "build:cap": "cross-env PORT=3000 BASE_PATH=/ vite build --config vite.config.ts",
    "build:mobile": "cross-env PORT=3000 BASE_PATH=/ VITE_APP_VARIANT=mobile vite build --config vite.config.ts",
    "build:tv": "cross-env PORT=3000 BASE_PATH=/ VITE_APP_VARIANT=tv vite build --config vite.config.ts --outDir dist/tv-public",
    "cap:sync": "npx cap sync android",
    "cap:sync:mobile": "npx cap sync android",
    "cap:sync:tv": "node scripts/sync-tv.js",
    "cap:open": "npx cap open android",
    "cap:open:mobile": "npx cap open android",
    "cap:open:tv": "node scripts/open-tv.js",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
